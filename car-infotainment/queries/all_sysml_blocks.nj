export all_sysml_blocks to "http://example.org/all_sysml_blocks"

import "http://vitruv.tools/methodologisttemplate/uvl" as uvl
import "http://vitruv.tools/methodologisttemplate/sysml"
import "http://vitruv.tools/metamodels/change/correspondence/1.0" as cors

from sysml.Block b
join cors.Correspondence cor
    on cor.leftEObjects.contains(b)
join uvl.Feature f
    on cor.rightEObjects.contains(f)
create SysMLBOMEntry {
    sysmlName   = b.name
    featureName = f.name
}
