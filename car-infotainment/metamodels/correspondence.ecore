<?xml version="1.0" encoding="UTF-8"?>
<ecore:EPackage xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" name="correspondence" nsURI="http://vitruv.tools/metamodels/change/correspondence/1.0"
    nsPrefix="correspondence">
  <!-- CorrespondenceObject as a replacement for EMF's EObject so NeoJoin can register it in its type registry. -->
  <eClassifiers xsi:type="ecore:EClass" name="CorrespondenceObject"
      instanceClassName="org.eclipse.emf.ecore.EObject"/>
  <eClassifiers xsi:type="ecore:EClass" name="Correspondences">
    <eStructuralFeatures xsi:type="ecore:EReference" name="correspondences" upperBound="-1"
        eType="#//Correspondence" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Correspondence" abstract="true">
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="tag" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="leftEObjects" upperBound="-1"
        eType="#//CorrespondenceObject"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="rightEObjects" upperBound="-1"
        eType="#//CorrespondenceObject"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="ManualCorrespondence" eSuperTypes="#//Correspondence"/>
</ecore:EPackage>
